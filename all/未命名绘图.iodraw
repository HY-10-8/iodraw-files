        </mxCell>
        <mxCell id="dvZCvjgUctOATZhmnxdy-8" value="接入 FE&#xa;Master / Follower / Observer 均可作为查询入口" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="dvZCvjgUctOATZhmnxdy-7">

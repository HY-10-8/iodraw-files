        </mxCell>
        <mxCell id="dvZCvjgUctOATZhmnxdy-13" value="接收 BE 返回的数据块&#xa;必要时做最终聚合 / 排序 / Limit" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="dvZCvjgUctOATZhmnxdy-7">

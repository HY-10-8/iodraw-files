        <mxCell id="Nz2Tu8nq5uW6-hyOi6lk-396" value="&lt;div&gt;创建表的示例SQL&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;CREATE TABLE 人员表 (&lt;/div&gt;&lt;div&gt;&amp;nbsp; ID INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; 姓名 VARCHAR(20),&lt;/div&gt;&lt;div&gt;&amp;nbsp; 入职日期 DATE&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;DUPLICATE KEY(ID)&lt;/div&gt;&lt;div&gt;PARTITION BY RANGE(入职日期) (&lt;/div&gt;&lt;div&gt;&amp;nbsp; PARTITION p202401 VALUES LESS THAN (&#39;2024-02-01&#39;),&lt;/div&gt;&lt;div&gt;&amp;nbsp; PARTITION p202402 VALUES LESS THAN (&#39;2024-03-01&#39;)&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;DISTRIBUTED BY HASH(ID) BUCKETS 3;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;根据 入职日期 进行分区&lt;/div&gt;&lt;div&gt;通过 ID 字段hash运算的结果进行分桶&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;" vertex="1" parent="1">

        </mxCell>
        <mxCell id="Nz2Tu8nq5uW6-hyOi6lk-386" value="缺的点有：&lt;div&gt;1、BE的备份怎么做的？&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;由FE调度、BE执行任务将数据备份到另外一个BE中&lt;br&gt;&lt;/div&gt;&lt;div&gt;2、&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-1220" y="5290" width="380" height="100" as="geometry" />
